# Server Configuration
NODE_ENV=production
PORT=5000
API_VERSION=v1

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/admin_panel
MONGODB_URI_DEV=mongodb://localhost:27017/admin_panel_dev

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Admin Configuration
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=Super Admin

# Session Configuration
SESSION_SECRET=session-secret-key-change-this
SESSION_EXPIRES_IN=3600000

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@adminpanel.com

# 2FA Configuration
TWO_FACTOR_APP_NAME=AdminPanel

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Backup Configuration
BACKUP_PATH=./backups
BACKUP_RETENTION_DAYS=30

# Security
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com
IP_WHITELIST_ENABLED=false
IP_WHITELIST=127.0.0.1,::1

# API Bridge (Customer App)
CUSTOMER_API_URL=http://localhost:4000/api
CUSTOMER_API_KEY=your-api-key

# Logging
LOG_LEVEL=info
LOG_MAX_FILES=30

# Webhook
WEBHOOK_SECRET=webhook-secret-key